{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main", "my-window-*"],
	"permissions": [
		"core:default",
		"opener:default",
		"fs:allow-app-read-recursive",
		"fs:allow-app-write-recursive",
		"fs:allow-rename",
		"fs:allow-remove",
		"dialog:allow-ask",
		"os:default",
		"sql:default",
    "sql:allow-execute"
	]
}
